# DeerStop Node server — environment variables
# Copy to .env and fill in the values:
#   cp .env.example .env

# Shared secret for time-limited TURN credentials (must match turnserver.conf)
TURN_SECRET=replace_with_a_long_random_string

# Bearer token that both the detection server and iOS app must present
AUTH_TOKEN=replace_with_a_long_random_string

# TURN server URL sent to WebRTC clients
TURN_URL=turn:node.polychronis.gr:3478
